# API Configuration
API_PORT=8000
API_HOST=0.0.0.0
DEBUG=True

# Database Configuration
# Use SQLite for local dev without Docker
# DATABASE_URL=sqlite+aiosqlite:///./code_review.db
# Use PostgreSQL for production/Docker
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/code_review

# Model Configuration
MODEL_DIR=./models
DATA_DIR=./data
MAX_CODE_LENGTH=100000
